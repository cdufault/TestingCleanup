  "scripts": {
    "start": "webpack serve --history-api-fallback --mode development",
    "build": "npm run antlr && webpack --mode production",
    "serve": "webpack serve --history-api-fallback --mode production --open --https --compress",
    "prettier": "prettier --write \"src/**/*.ts?(x)\"",
    "lint": "eslint \"src/**/*.ts?(x)\"",
    "lint-fix": "eslint --fix \"src/**/*.ts?(x)\"",
    "copy": "ncp ../../node_modules/@arcgis/core/assets ./public/assets",
    "test": "npm run antlr && jest",
    "get-version": "awk -F '\"' '/\"version\"/{if (ENVIRON[\"BUILD_ID\"]) print $4 \".b\" ENVIRON[\"BUILD_ID\"]; else print $4 \".devel_\" ENVIRON[\"USERNAME\"] \"_\" systime()}' package.json",
    "create-version": "npm run --silent get-version > version.txt",
    "antlr": "mkdirp ./src/components/classification/gen && antlr4ng -Dlanguage=TypeScript -visitor -listener -lib ./src/components/classification/gen -Xexact-output-dir -o ./src/components/classification/gen ./src/components/classification/grammar/*.g4"
  },
