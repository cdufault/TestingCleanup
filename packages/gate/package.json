    "@mui/material": "^5.11.6",
    "@reduxjs/toolkit": "^1.9.1",
    "@stratcom/lib-functions": "1.0.0",
    "@stratcom/react-widget-lib": "0.1.0",
    "calcite-ui-icons-react": "^0.38.0",
