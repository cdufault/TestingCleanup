  },
  "scripts": {
    "start": "craco start",
    "build": "craco build && npm run copy && npm run create-version ",
    "test": "craco test --passWithNoTests",
    "eject": "craco eject",
    "prettier": "prettier --write \"src/**/*.ts?(x)\"",
    "copy": "ncp ../../node_modules/@arcgis/core/assets ./public/assets",
    "get-version": "awk -F '\"' '/\"version\"/{if (ENVIRON[\"BUILD_ID\"]) print $4 \".b\" ENVIRON[\"BUILD_ID\"]; else print $4 \".devel_\" ENVIRON[\"USERNAME\"] \"_\" systime()}' package.json",
    "create-version": "npm run --silent get-version > version.txt"
  },
  "devDependencies": {
    "@craco/craco": "^7.1.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^11.2.3",
    "@testing-library/user-event": "^13.5.0",
    "@types/node": "^16.18.4",
    "@types/react": "^18.0.27",
    "@types/react-dom": "^18.0.10",
    "@types/react-router-dom": "^5.3.3",
    "react-scripts": "5.0.1",
    "typescript": "^4.9.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "last 2 versions",
      "not dead",
      "not ie 11",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
